{
  "name": "novu-cloudflare-agent-example",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  },
  "ai": {
    "binding": "AI"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "CleaningBot",
        "class_name": "CleaningBot"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["WineBot"]
    },
    {
      "tag": "v2",
      "renamed_classes": [{ "from": "WineBot", "to": "CleaningBot" }]
    }
  ]
}
