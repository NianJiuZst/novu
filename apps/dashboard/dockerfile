FROM node:20-alpine3.20 AS builder
RUN apk add g++ make py3-pip
ENV NX_DAEMON=false

WORKDIR /usr/src/app

RUN apk add --no-cache bash
RUN npm install -g pnpm@10.16.1 --loglevel notice

COPY .npmrc .
COPY package.json .

COPY apps/dashboard ./apps/dashboard
COPY libs ./libs
COPY packages ./packages
COPY enterprise ./enterprise
COPY tsconfig.json .

COPY nx.json .
COPY pnpm-workspace.yaml .
COPY pnpm-lock.yaml .

RUN --mount=type=cache,id=pnpm-store-dashboard,target=/root/.pnpm-store\
  pnpm install --frozen-lockfile --unsafe-perm

RUN CI='' pnpm build:dashboard --skip-nx-cache

FROM node:20-alpine3.20

RUN npm install -g http-server --loglevel notice

WORKDIR /app

COPY --from=builder /usr/src/app/apps/dashboard/dist /app/dist
COPY --from=builder /usr/src/app/apps/dashboard/package.json /app/package.json
COPY --from=builder /usr/src/app/apps/dashboard/docker-entrypoint.sh /app/docker-entrypoint.sh

# OpenShift compatibility: Set group ownership to 0 (root group) and make group-writable
# OpenShift runs with arbitrary UIDs but keeps GID 0, allowing write access
# Make /app/dist writable so sed can create temp files
RUN chgrp -R 0 /app && \
    chmod -R g+rwX /app && \
    chmod 775 /app/dist && \
    chmod 664 /app/dist/index.html && \
    chmod +x /app/docker-entrypoint.sh

# Run as UID 1000 with GID 0 (root group) for OpenShift compatibility
USER 1000:0
ENTRYPOINT [ "/app/docker-entrypoint.sh" ]
# Expose the port the app runs on
EXPOSE 4000
CMD [ "http-server", "dist", "-p", "4000", "-d", "false", "--proxy", "http://localhost:4000?" ]