{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strictNullChecks": true,
    "target": "es6",
    "jsx": "react",
    "esModuleInterop": true,
    "module": "Preserve",
    "moduleResolution": "bundler"
  },
  "exclude": ["node_modules"]
}
