{
  "terminals": [
    {
      "name": "API Server",
      "command": "pnpm start:api"
    },
    {
      "name": "Dashboard",
      "command": "pnpm start:dashboard"
    },
    {
      "name": "Worker",
      "command": "pnpm start:worker"
    }
  ],
  "install": "git submodule update --init --recursive && pnpm install && pnpm build:v2",
  "start": "cd scripts && node setup-env-files.js && cd ..",
  "build": {
    "context": ".",
    "dockerfile": "Dockerfile"
  }
}
